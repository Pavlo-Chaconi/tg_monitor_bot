# ──────────────────────────────────────────────
#  Telegram
# ──────────────────────────────────────────────
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# ID чата/группы/канала куда слать отчёты
# Для личных сообщений: ваш числовой ID (узнать у @userinfobot)
# Для группы: -100xxxxxxxxxx
TELEGRAM_CHAT_ID=-1001234567890

# Опционально: список admin-id через запятую (пока не используется)
TELEGRAM_ADMIN_IDS=

# Прокси для Telegram Bot API (нужен, если api.telegram.org заблокирован)
# SOCKS5:  socks5://192.168.14.172:1080
# SOCKS5 с паролем: socks5://user:pass@host:1080
# HTTP:    http://192.168.14.172:3128
TELEGRAM_PROXY_URL=

# ──────────────────────────────────────────────
#  Prometheus
# ──────────────────────────────────────────────
PROMETHEUS_URL=http://192.168.1.10:9090
# Если Prometheus за Basic Auth:
PROMETHEUS_USERNAME=
PROMETHEUS_PASSWORD=

# ──────────────────────────────────────────────
#  TrueNAS
# ──────────────────────────────────────────────
TRUENAS_URL=http://192.168.1.20

# Рекомендуется: API-ключ (создать в TrueNAS → System → API Keys)
TRUENAS_API_KEY=1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Альтернатива: логин/пароль (если нет API-ключа)
TRUENAS_USERNAME=
TRUENAS_PASSWORD=

# ──────────────────────────────────────────────
#  Расписание отчётов
# ──────────────────────────────────────────────
# Формат cron: hour и minute
# Примеры:
#   Каждый час в :00  → REPORT_HOUR=* REPORT_MINUTE=0
#   В 8:00 и 20:00    → REPORT_HOUR=8,20 REPORT_MINUTE=0
#   Каждые 30 минут   → REPORT_HOUR=* REPORT_MINUTE=0,30
REPORT_HOUR=*
REPORT_MINUTE=0

# Часовой пояс
TIMEZONE=Europe/Moscow

# ──────────────────────────────────────────────
#  Мониторинг почты (Яндекс 360 — оплата)
# ──────────────────────────────────────────────
# Интервал проверки в часах (по умолчанию 6)
MAIL_CHECK_INTERVAL_HOURS=6

# Ящик 1: zavod@sibgydral.ru (Яндекс 360)
# Пароль: создать пароль приложения в Яндекс ID → Безопасность → Пароли приложений
MAIL1_LABEL=zavod@sibgydral.ru
MAIL1_IMAP_SERVER=imap.yandex.ru
MAIL1_IMAP_PORT=993
MAIL1_USERNAME=zavod@sibgydral.ru
MAIL1_PASSWORD=

# Ящик 2: p.kutischev@rtimail.ru
# MAIL2_IMAP_SERVER — узнать у провайдера (например: imap.rtimail.ru или mail.rtimail.ru)
MAIL2_LABEL=p.kutischev@rtimail.ru
MAIL2_IMAP_SERVER=imap.rtimail.ru
MAIL2_IMAP_PORT=993
MAIL2_USERNAME=p.kutischev@rtimail.ru
MAIL2_PASSWORD=
